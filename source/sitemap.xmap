    </map:match>
    
    <map:match pattern="xmlcolofon.xml">
      <map:generate src="xml/colofon.xml" label="adsXML"/>
      <map:transform src="stylesheets/xml.xsl">
        <map:parameter name="use-request-parameters" value="true"/>
      </map:transform>
      <map:serialize type="xml"/>
    </map:match>
    
    <map:match pattern="search.html">
      <map:generate src="search.html"/>
      <map:serialize type="xhtml"/>
    </map:match>
    
    <map:match pattern="blank.html">
      <map:generate src="stylesheets/blank.html"/>
      <map:serialize type="xhtml"/>
    </map:match>
    
 

  </map:pipeline>

<!-- ============================================================== -->
<!-- this one for auxiliary file types                              -->
<!-- ============================================================== -->
  <map:pipeline>

    <map:match pattern="**.xml">
      <map:read mime-type="text/xml" src="xml/{1}.xml"/>
    </map:match>

    <map:match pattern="**.dtd">
      <map:read mime-type="text/plain" src="dtd/{1}.dtd"/>
    </map:match>

    <map:match pattern="styleDoc/*.css">
      <map:read mime-type="text/css" src="css/{1}.css"/>
    </map:match>

    <map:match pattern="**.css">
      <map:read mime-type="text/css" src="{1}.css"/>
    </map:match>

    <map:match pattern="**.js">
      <map:read mime-type="text/javascript" src="{1}.js"/>
    </map:match>

    <map:match pattern="**.gif">
      <map:read mime-type="text/gif" src="{1}.gif"/>
    </map:match>

    <map:match pattern="**.swf">
      <map:read mime-type="text/gif" src="{1}.swf"/>
    </map:match>

    <map:match pattern="**.JPG">
      <map:read mime-type="text/css" src="{1}.JPG"/>
    </map:match>

    <map:match pattern="**.jpg">
      <map:read mime-type="text/css" src="{1}.jpg"/>
    </map:match>

    <map:match pattern="**.ent">
      <map:read mime-type="text/css" src="xml/xmlsnips/{1}.ent"/>
    </map:match>
    
    <map:match pattern="~*">
      <map:redirect-to uri="ads.htm?ads.htm?text=docfacs&amp;document={0}&amp;page="/>
    </map:match>

  </map:pipeline>

</map:pipelines>
</map:sitemap>
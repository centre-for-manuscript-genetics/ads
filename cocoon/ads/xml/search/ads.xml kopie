</p>
<p><seg n="257" base="z257"><hi rend="i">En <app TEIform="app" id="d0e5411"><rdg TEIform="rdg" wit="AdsM1 AdsM2a AdsT1 AdsM3a AdsD1 AdsD2 AdsD3 AdsD4 AdsZM2 AdsZM3 ">zoo</rdg><rdg TEIform="rdg" wit="AdsD5 AdsP1a AdsP2 AdsD6 AdsZP1 ">zo</rdg></app> is het goed ook.</hi></seg>
<lb ed="AdsM2a AdsM2b AdsM2c AdsM2d AdsM2e AdsM2f AdsD1 AdsD2 AdsD3 AdsD4 AdsD5 AdsP1a AdsP2 AdsD6 AdsZP1 "/>
<seg n="258" base="z258">Is het <app TEIform="app" id="d0e5412"><rdg TEIform="rdg" wit="AdsM1 AdsM2a AdsT1 AdsM3a AdsD1 AdsD2 AdsD3 AdsD4 AdsZM2 AdsZM3 ">zoo</rdg><rdg TEIform="rdg" wit="AdsD5 AdsP1a AdsP2 AdsD6 AdsZP1 ">zo</rdg></app> niet <app TEIform="app" id="azze642"><rdg TEIform="rdg" wit="AdsM1 "><hi rend="i">waar</hi></rdg><rdg TEIform="rdg" wit="AdsM2a AdsT1 AdsM3a AdsD1 AdsD2 AdsD3 AdsD4 AdsD5 AdsP1a AdsP2 AdsD6 AdsZP1 AdsZM2 AdsZM3 ">waar</rdg></app><app TEIform="app" id="azze644"><rdg TEIform="rdg" wit="AdsM1 "></rdg><rdg TEIform="rdg" wit="AdsM2a AdsT1 AdsM3a AdsD1 AdsD2 AdsD3 AdsD4 AdsD5 AdsP1a AdsP2 AdsD6 AdsZP1 AdsZM2 AdsZM3 ">,</rdg></app> dan is het <app TEIform="app" id="d0e5413"><rdg TEIform="rdg" wit="AdsM1 AdsM2a AdsT1 AdsM3a AdsD1 AdsD2 AdsD3 AdsD4 AdsZM2 AdsZM3 ">zoo</rdg><rdg TEIform="rdg" wit="AdsD5 AdsP1a AdsP2 AdsD6 AdsZP1 ">zo</rdg></app> toch <app TEIform="app" id="azze643"><rdg TEIform="rdg" wit="AdsM1 "><hi rend="i">goed</hi></rdg><rdg TEIform="rdg" wit="AdsM2a AdsT1 AdsM3a AdsD1 AdsD2 AdsD3 AdsD4 AdsD5 AdsP1a AdsP2 AdsD6 AdsZP1 AdsZM2 AdsZM3 ">goed</rdg></app>.</seg> <seg n="259" base="z259">Als <app TEIform="app" id="azze645"><rdg TEIform="rdg" wit="AdsM1 ">ik</rdg><rdg TEIform="rdg" wit="AdsM2a AdsT1 AdsM3a AdsD1 AdsD2 AdsD3 AdsD4 AdsD5 AdsP1a AdsP2 AdsD6 AdsZP1 AdsZM2 AdsZM3 "><hi rend="i">ik</hi></rdg></app> maar <app TEIform="app" id="azze646"><rdg TEIform="rdg" wit="AdsM1 ">niet doende ben te veel te bewijzen.</rdg><rdg TEIform="rdg" wit="AdsM2a AdsT1 AdsM3a AdsD1 AdsD2 AdsD3 AdsD4 AdsD5 AdsP1a AdsP2 AdsD6 AdsZP1 AdsZM2 AdsZM3 ">tevreden ben en verder zorg dat het publiek waar krijgt naar zijn geld.</rdg></app></seg> <seg n="260" base="z260"><app TEIform="app" id="azze647"><rdg TEIform="rdg" wit="AdsM1 "></rdg><rdg TEIform="rdg" wit="AdsM2a AdsT1 AdsM3a AdsD1 AdsD2 AdsD3 AdsD4 AdsD5 AdsP1a AdsP2 AdsD6 AdsZP1 AdsZM2 AdsZM3 ">Toch wordt het nu tijd dat ik ophoud, of ik bewijs te veel.</rdg></app></seg>
